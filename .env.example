# ── Supabase ───────────────────────────────────────────────
# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Service-role key (server-only secret — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=
# Private storage bucket name that holds original + signed PDFs
SUPABASE_BUCKET=documents

# ── Admin auth ─────────────────────────────────────────────
# bcrypt hash of your admin password. Generate with:  npm run hash-password
ADMIN_PASSWORD_HASH=
# Random 32+ char secret used to sign the admin session JWT.
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=

# ── App ────────────────────────────────────────────────────
# Public base URL — used to build the shareable signing links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
