# ── Control-plane Supabase (the PLATFORM's own project) ────
# Holds only the `agencies` table (accounts + encrypted connection settings).
# Each agency connects their OWN Supabase from the in-app Settings page.
# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Anon (publishable) key for the CONTROL project — used by the browser for
# Supabase Auth (sign-up / login / password reset). Public by design.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key for the CONTROL project (server-only secret).
SUPABASE_SERVICE_ROLE_KEY=

# ── Secrets ────────────────────────────────────────────────
# 32-byte base64 key used to encrypt agency secrets (their Supabase + Resend
# keys) at rest. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=
# Random 32+ char secret used to sign the session JWT. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=

# ── Platform-hosted data plane (optional) ──────────────────
# A SHARED Supabase instance (e.g. self-hosted on a VPS via Coolify) that
# agencies can use instead of bringing their own. Leave blank to disable the
# "use Studio Happens hosting" option. Rows are isolated per agency via
# agency_id. Run db/schema.sql once on this instance.
HOSTED_SUPABASE_URL=
HOSTED_SUPABASE_SERVICE_KEY=
HOSTED_SUPABASE_BUCKET=documents

# ── Platform email (Resend) ────────────────────────────────
# Used for auth OTP emails (signup verification + password-change confirm).
# Get a free key at https://resend.com — one account for the whole platform.
# Each agency separately configures their own Resend key in Settings for
# sending signed PDFs; this key is only for auth/OTP emails.
RESEND_API_KEY=re_...
# Optional "From" address. Defaults to Studio Happens Sign <onboarding@resend.dev>
# (Resend sandbox, works without domain verification).
# To use a custom domain, verify it in your Resend dashboard first.
RESEND_FROM=Studio Happens Sign <onboarding@resend.dev>

# ── Guest mode (no-signup) ─────────────────────────────────
# Guest documents are stored in the control Supabase under a separate bucket.
# Run db/schema.sql on the control project and create this bucket first.
GUEST_STORAGE_BUCKET=guest-documents
# Optional secret to protect the /api/cleanup endpoint. If set, callers must
# pass ?secret=VALUE. Leave blank to run cleanup from admin only.
CLEANUP_SECRET=

# ── App ────────────────────────────────────────────────────
# Public base URL — a fallback for building signing links (the admin UI
# normally builds them from the live browser origin).
NEXT_PUBLIC_APP_URL=http://localhost:3000
